# Copy this file to .env and fill in real values. Never commit .env itself.

# Which free LLM backend to use: "gemini" (default) or "groq"
LLM_PROVIDER=gemini

# Gemini: get a free key (no card required) at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq: get a free key (no card required) at https://console.groq.com/keys
# Only needed if LLM_PROVIDER=groq
GROQ_API_KEY=

# Optional: if set, run failures/alerts post here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Supabase (database) -- optional, but required for the crawler to publish
# into the same database cardscope reads from. Without these, the crawler
# still runs fine and writes to data/{provider}/latest.json as before.
#
# Project Settings -> API in your Supabase dashboard:
#   SUPABASE_URL          -> "Project URL"
#   SUPABASE_SERVICE_KEY  -> "service_role" secret key (NOT the anon key --
#                            this bypasses Row Level Security so the
#                            crawler can write; never expose it to a
#                            browser/frontend)
# Run supabase/schema.sql in the SQL Editor once before first use.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional tuning (defaults shown)
REQUEST_TIMEOUT_S=15
REQUEST_DELAY_S=1.5
MAX_URLS_PER_PROVIDER=60
CLASSIFY_MODEL=gemini-2.5-flash-lite
EXTRACT_MODEL=gemini-2.5-flash-lite
LLM_CALL_DELAY_S=4.5
LLM_MAX_RETRIES=3
CRAWLER_USER_AGENT=CardCompareBot/1.0 (+https://example.com/bot; contact=admin@example.com)

# --- If using Groq instead, use model names like these: ---
# LLM_PROVIDER=groq
# CLASSIFY_MODEL=llama-3.3-70b-versatile
# EXTRACT_MODEL=llama-3.3-70b-versatile
