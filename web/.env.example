# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Supabase (card database, populated by credit-card-crawler) ---
# Paste these in from your Supabase project: Project Settings -> API.
# VITE_SUPABASE_ANON_KEY is the public "anon" key -- safe to ship to the
# browser, since Row Level Security only allows it to read active cards
# (see credit-card-crawler/supabase/schema.sql). Never put the
# service_role key here.
# If left blank, the app runs fine using built-in mock card data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: AI search parsing endpoint (a Supabase Edge Function that
# proxies Groq server-side -- see supabase/functions/parse-search/index.ts
# for the function and its deploy instructions). When unset, the search
# bar still auto-toggles filters using the built-in synonym parser; the
# LLM only adds coverage for unusual phrasings.
VITE_SEARCH_PARSER_URL=
